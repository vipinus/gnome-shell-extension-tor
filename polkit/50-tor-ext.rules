// 50-tor-ext.rules — polkit JS rule for gnome-shell-extension tor-ext.
//
// Allows active local session users to start/stop/reload tor@default.service
// (and the meta tor.service) via systemd1 DBus with auth_admin_keep, so the
// password is prompted once per session, not per click.
//
// Install to: /etc/polkit-1/rules.d/50-tor-ext.rules  (root:root, 0644)

polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") return;
    if (!subject.active || !subject.local) return;

    var unit = action.lookup("unit");
    if (unit !== "tor.service" &&
        unit !== "tor@default.service" &&
        unit !== "tor@.service") return;

    var verb = action.lookup("verb");
    switch (verb) {
        case "start":
        case "stop":
        case "reload":
        case "restart":
        case "try-restart":
        case "reload-or-restart":
            return polkit.Result.AUTH_ADMIN_KEEP;
    }
});
