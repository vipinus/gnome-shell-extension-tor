// 51-tor-ext-tun2socks.rules — allow active local users to start/stop the
// distro tor service AND the tor-ext tun2socks side service without a password
// prompt. Installed by scripts/install-tor-tun2socks.sh.
//
// Scope is limited to the exact unit names involved; other units stay under
// default polkit policy. Use YES (not AUTH_ADMIN_KEEP) because a transparent-
// proxy toggle in Quick Settings is expected to be instantaneous, and the
// one-time privileged install (scripts/install-tor-tun2socks.sh) has already
// established the user's intent.
//
// v0.6.0: replaces the old tor-ext.service rule. Since tor itself is now the
// distro's own unit, both possible names (tor.service / tor@default.service)
// are allow-listed — only one will exist on a given host.
//
// Install to: /etc/polkit-1/rules.d/51-tor-ext-tun2socks.rules  (root:root, 0644)

polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") return;
    if (!subject.active || !subject.local) return;

    var unit = action.lookup("unit") || "";
    if (unit !== "tor.service" &&
        unit !== "tor@default.service" &&
        unit !== "tor-ext-tun2socks.service") return;

    var verb = action.lookup("verb") || "";
    switch (verb) {
        case "start":
        case "stop":
        case "restart":
        case "reload":
        case "try-restart":
        case "reload-or-restart":
            return polkit.Result.YES;
    }
});
