[Unit]
Description=Tor for tor-ext GNOME extension (system mode)
Documentation=https://github.com/vipinus/gnome-shell-extension-tor
After=network.target
Before=tor-ext-tun2socks.service

[Service]
Type=simple
User=_tor-ext
Group=_tor-ext
WorkingDirectory=/var/lib/tor-ext
ExecStart=@TOR_BIN@ -f /etc/tor-ext/torrc
Restart=on-failure
RestartSec=5
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes
ReadWritePaths=/var/lib/tor-ext
# CAP_NET_BIND_SERVICE not needed — we bind > 1024.

[Install]
WantedBy=multi-user.target
